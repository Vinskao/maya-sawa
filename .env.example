# Maya Sawa 雙數據庫配置範例

# 主數據庫配置 (用於 articles 表)
DB_HOST=your-main-db-host.com
DB_PORT=5432
DB_DATABASE=your_main_database
DB_USERNAME=your_main_username
DB_PASSWORD=your_main_password
DB_SSLMODE=require

# Paprika / git commit knowledge database configuration
PAPRIKA_DB_TYPE=postgresql
PAPRIKA_DB_HOST=your-main-db-host.com
PAPRIKA_DB_PORT=5432
PAPRIKA_DB_DATABASE=your_main_database
PAPRIKA_DB_USERNAME=your_main_username
PAPRIKA_DB_PASSWORD=your_main_password
PAPRIKA_DB_SSLMODE=require

# Keycloak resource server configuration
KEYCLOAK_AUTH_SERVER_URL=https://peoplesystem.tatdvsonorth.com
KEYCLOAK_REALM=PeopleSystem
KEYCLOAK_CLIENT_ID=peoplesystem
AI_RATE_LIMIT_MANAGER_PER_MINUTE=10
AI_RATE_LIMIT_STANDARD_PER_MINUTE=1
AI_RATE_LIMIT_ANONYMOUS_PER_MINUTE=1
AI_RATE_LIMIT_WINDOW_SECONDS=60
GIT_COMMIT_REQUIRED_ROLE=manage-users
GIT_COMMIT_TRIVIAL_MIN_LINES=5
GIT_COMMIT_TRIVIAL_KEYWORDS=typo,rename,format,lint,chore: rename,whitespace
GIT_COMMIT_SUMMARY_MAX_CHARS=2000

# 人員數據庫配置 (用於 people 和 weapon 表)
PEOPLE_DB_HOST=your-people-db-host.com
PEOPLE_DB_PORT=5432
PEOPLE_DB_DATABASE=your_people_database
PEOPLE_DB_USERNAME=your_people_username
PEOPLE_DB_PASSWORD=your_people_password
PEOPLE_DB_SSLMODE=require

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_ORGANIZATION=your_organization_id

# Redis 配置
REDIS_HOST=localhost
REDIS_CUSTOM_PORT=6379
REDIS_PASSWORD=your_redis_password

# API 配置
PUBLIC_API_BASE_URL=https://your-api-base-url.com
PUBLIC_TYMB_URL=https://your-tymb-url.com

# 向量搜索配置
MATCH_COUNT=5
SIMILARITY_THRESHOLD=0.7

# 嵌入配置
FORCE_LOCAL_EMBEDDING=true
VALIDATE_UPSTREAM_EMBEDDING=true

# 同步配置
ENABLE_AUTO_SYNC_ON_STARTUP=true
ENABLE_PERIODIC_SYNC=true
SYNC_INTERVAL_DAYS=3
SYNC_HOUR=3
SYNC_MINUTE=0

# 人員和武器同步配置
ENABLE_PEOPLE_WEAPONS_SYNC=true
ENABLE_PEOPLE_WEAPONS_PERIODIC_SYNC=true

# 日誌配置
LOG_LEVEL=INFO 
